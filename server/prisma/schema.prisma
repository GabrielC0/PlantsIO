generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Programmes d'arrosage ──────────────────────────────────────
model Schedule {
  id         String            @id @default(uuid())
  name       String            @db.VarChar(50)
  enabled    Boolean           @default(true)
  times      Json              // string[]     ex: ["07:00", "18:00"]
  activeDays Json              // DayOfWeek[]  ex: ["Lun", "Mer", "Ven"]
  duration   Int               @default(300)  // secondes
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  sessions   WateringSession[]

  @@map("schedules")
}

// ── Historique des arrosages ───────────────────────────────────
model WateringSession {
  id              String    @id @default(uuid())
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int       @default(0)
  volumeLiters    Float     @default(0.0)
  mode            String    @db.VarChar(10)   // "auto" | "manual"
  scheduleId      String?
  schedule        Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  triggeredBy     String    @default("user")  @db.VarChar(50)
  status          String    @default("in_progress") @db.VarChar(20) // "completed"|"in_progress"|"aborted"
  createdAt       DateTime  @default(now())

  @@index([startedAt])
  @@index([status])
  @@index([scheduleId])
  @@map("watering_sessions")
}

// ── Configuration persistée (clé/valeur) ──────────────────────
model SystemConfig {
  key       String   @id @db.VarChar(50)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_config")
}
